# --- Database ---
# PostGIS (via docker compose). If unset or unreachable in dev, backend falls
# back to SQLite at backend/dev.db (geometry stored as GeoJSON only).
DATABASE_URL=postgresql+psycopg2://geoai:geoai@localhost:5432/geoai

# --- Redis (job queue + cache). Optional in dev; falls back to in-process. ---
REDIS_URL=redis://localhost:6379/0

# --- Object storage (MinIO local / S3 compatible). Optional in dev; falls
# back to local filesystem at backend/storage/. ---
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=geoai-files
S3_ACCESS_KEY=geoai
S3_SECRET_KEY=geoai-secret

# --- Map / 3D providers (backend .env only — not set by end users) ---
GOOGLE_MAPS_API_KEY=
CESIUM_ION_TOKEN=
MAPBOX_TOKEN=

# --- AI providers (backend .env only; MockAIProvider used when all blank) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# --- App ---
APP_SECRET=dev-secret-change-me
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000
