# =============================================================================
# SiteGeoAI / GeoAI 3D Construction Planner — environment variables
# Copy to `.env` in the repo root (backend reads via pydantic-settings).
# Frontend public vars also go in `frontend/.env.local`.
# =============================================================================

# --- App / security ---
# Dev: weak secret + JWT optional. Production: strong secret + JWT required.
APP_SECRET=change-me-in-production
ENVIRONMENT=development
AUTH_REQUIRE_JWT=false
# Dev mock user role when AUTH_REQUIRE_JWT=false (admin or user).
DEV_MOCK_USER_ROLE=admin
# Set true in production (matches backend). Frontend uses this to redirect on 401.
NEXT_PUBLIC_AUTH_REQUIRE_JWT=false
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000

# Max wall-clock time for a single design generation job (seconds).
GENERATION_JOB_TIMEOUT_SECONDS=300

# Usage limits and rate limiting (set false to disable in local dev).
USAGE_LIMITS_ENABLED=true
RATE_LIMITING_ENABLED=true
# Enqueue design jobs to Arq worker when Redis is available (true on Render).
USE_ARQ_WORKER=false

# Optional error tracking (backend initializes only when SENTRY_DSN is set)
SENTRY_DSN=
SENTRY_ENVIRONMENT=
SENTRY_TRACES_SAMPLE_RATE=0.1
# Frontend (optional — add @sentry/nextjs to enable client reporting)
NEXT_PUBLIC_SENTRY_DSN=

# --- Database ---
# Production: PostgreSQL + PostGIS (see docker-compose.yml).
# Dev fallback: SQLite at backend/dev.db if Postgres is unreachable.
DATABASE_URL=postgresql+psycopg2://geoai:geoai@localhost:5432/geoai

# --- Redis / jobs ---
# Production: required for durable job status across restarts.
# Dev: optional — falls back to in-process in-memory job store.
REDIS_URL=redis://localhost:6379/0

# --- Storage (MinIO local / S3-compatible) ---
# Production: configure S3 or MinIO — do not rely on local disk.
# Dev fallback: backend/storage/ on the local filesystem.
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=geoai-files
S3_ACCESS_KEY=geoai
S3_SECRET_KEY=your-minio-secret

# --- AI providers (backend only — never commit real keys) ---
# AI_PROVIDER: ollama | openai | anthropic | mock | auto
AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_TIMEOUT_SECONDS=120

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
# Gemini provider is not implemented yet; use openai | anthropic | ollama | mock

# --- Maps / terrain (backend .env) ---
# Restrict keys by domain/referrer in provider dashboards.
GOOGLE_MAPS_API_KEY=
CESIUM_ION_TOKEN=
MAPBOX_TOKEN=

# --- Frontend public map vars (browser-exposed; use referrer restrictions) ---
# NEXT_PUBLIC_MAP_ENGINE: maplibre (default) | cesium
NEXT_PUBLIC_MAP_ENGINE=maplibre
NEXT_PUBLIC_MAPBOX_TOKEN=
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
